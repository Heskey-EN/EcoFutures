# Copy to .env.local for local dev, and set the same in Vercel →
# Settings → Environment Variables for production.

# ── Stripe ────────────────────────────────────────────────────────────────
# Secret key — powers /api/checkout (server-side only, never exposed).
# Use a TEST key (sk_test_...) while testing; a LIVE key (sk_live_...) in prod.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Webhook signing secret — powers /api/stripe-webhook. Create a webhook in
# Stripe → Developers → Webhooks pointing at https://ecofutures.uk/api/stripe-webhook
# for events: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted. Stripe shows the whsec_... signing secret.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ── Supabase (membership provisioning) ────────────────────────────────────
# The service_role key is server-only — never put it in the frontend.
EPC_SUPABASE_URL=https://your-epc-checker-project.supabase.co
EPC_SUPABASE_SERVICE_ROLE_KEY=your_epc_checker_service_role_key

CAVWALL_SUPABASE_URL=https://your-cavwall-project.supabase.co
CAVWALL_SUPABASE_SERVICE_ROLE_KEY=your_cavwall_service_role_key

# ── Optional: override the EmailJS contact-form config (defaults baked in) ──
# VITE_EMAILJS_SERVICE=
# VITE_EMAILJS_TEMPLATE=
# VITE_EMAILJS_PUBLIC_KEY=
