# Copy to .env.local for local dev, and set the same in Vercel →
# Settings → Environment Variables for production.

# Stripe secret key — powers /api/checkout (server-side only, never exposed).
# Use a TEST key (sk_test_...) while testing; a LIVE key (sk_live_...) in production.
STRIPE_SECRET_KEY=sk_test_your_key_here

# Optional — override the EmailJS contact-form config (defaults are baked in):
# VITE_EMAILJS_SERVICE=
# VITE_EMAILJS_TEMPLATE=
# VITE_EMAILJS_PUBLIC_KEY=
